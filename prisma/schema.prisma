  entityType    String? // Project, Task, Milestone, Issue, Change Request, Invoice, Expense, Contract, Customer, Vendor, Employee
  entityId      String?
  version       Int      @default(1)
  parentDocId   String? // for version history
  tags          String[] @default([])
  description   String?  @db.Text
  permission    String?  @default("Owner") // Owner, Manager, Editor, Viewer, Guest
  downloadCount Int      @default(0)
  viewCount     Int      @default(0)
