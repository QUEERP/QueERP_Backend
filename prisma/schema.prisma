generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String
  createdAt        DateTime       @default(now())
  isActive         Boolean        @default(true)
  role             UserRole       @default(USER)
  updatedAt        DateTime       @updatedAt
  activeBusinessId String?
  employees        Employee?
  memberships      BusinessUser[]
  businessesOwned  Business[]     @relation("BusinessOwner")
  activeBusiness   Business?      @relation("ActiveBusiness", fields: [activeBusinessId], references: [id])
  settings         Settings[]     @relation("SettingsToUser")

  resetToken       String?
  resetTokenExpiry DateTime?

  // Project Operations Relations
  projectManagerOf       Project[]              @relation("ProjectManager")
  assignedTasks          ProjectTask[]          @relation("TaskAssignedTo")
  assignedReqs           ProjectRequirement[]   @relation("RequirementAssignedTo")
  milestonesOwned        ProjectMilestone[]     @relation("MilestoneOwner")
  issuesReported         ProjectIssue[]         @relation("IssueReporter")
  issuesAssigned         ProjectIssue[]         @relation("IssueAssignee")
  changeRequests         ProjectChangeRequest[] @relation("ChangeRequestOwner")
  changeRequestsAssigned ProjectChangeRequest[] @relation("ChangeRequestAssignee")
  documentsUploaded      ProjectDocument[]      @relation("DocumentUploader")
  budgetApprovals        ProjectBudgetHistory[] @relation("BudgetHistoryApprover")

  managedExpenses Expense[]       @relation("ExpenseManager")
  financeExpenses Expense[]       @relation("ExpenseFinance")
  projectBudgets  ProjectBudget[]

  @@map("users")
  ticketComments TicketComment[]
}
model Business {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  country            Country   @default(INDIA)
  state              String?
  city               String?
  currency           String    @default("INR")
  gstNumber          String?
  vatNumber          String?
  financialYearStart DateTime?
  financialYearEnd   DateTime?

  // Enterprise Details
  legalName    String?
  businessType String?
  industry     String?
  description  String? @db.Text
  pinCode      String?
  timeZone     String?
  language     String?
  emirate      String?

  // India Specific
  pan                 String?
  tan                 String?
  msmeNumber          String?
  gstRegistrationType String?

  // UAE Specific
  vatRegistrationDate DateTime?
  vatRegistrationType String?
  //   accounts            Account[]
  activities          Activity[]
  bills               Bill[]
  //   Campaign            Campaign[]
  contracts           Contract[]
  contractTypes       ContractType[]
  creditNotes         CreditNote[]
  //   CrmTask             CrmTask[]
  customerContacts    CustomerContact[]
  deals               Deal[]
  //   EmailLog            EmailLog[]
  employees           Employee[]
  expenses            Expense[]
  //   journalEntries      JournalEntry[]
  leads               Lead[]
  //   LeadConversionLog   LeadConversionLog[]
  //   Note                Note[]
  overtimes           Overtime[]
  //   products            Product[]
  //   projects            Project[]
  //   PurchaseOrder       PurchaseOrder[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  settings            Settings?
  //   timeEntries         TimeEntry[]
  attendances         Attendance[]
  vendors             Vendor[]
  warehouses          Warehouse[]
  //  audit_logs          audit_logs[]
  //  batches             batches[]
  //  brands              brands[]
  users               BusinessUser[]
  owner               User              @relation("BusinessOwner", fields: [ownerId], references: [id])
  //  categories          categories[]
  customers           Customer[]
  //  goods_receive_notes goods_receive_notes[]
  invoices            Invoice[]
  //  notifications       notifications[]
  payments            Payment[]
  //  purchase_requests   purchase_requests[]
  //   purchase_returns    purchase_returns[]
  //   recurring_invoices  recurring_invoices[]
  roles               Role[]
  //   sales_returns       sales_returns[]
  //   serial_numbers      serial_numbers[]
  //   stock_adjustments   stock_adjustments[]
  stockMovements      StockMovement[]
  //   stock_transfers     stock_transfers[]
  subscription        Subscription?
  //   units               units[]
  activeUsers         User[]            @relation("ActiveBusiness")

  // Phase2 relations
  Note                   Note[]
  EmailLog               EmailLog[]
  Campaign               Campaign[]
  CrmTask                CrmTask[]
  LeadConversionLog      LeadConversionLog[]
  categories             Category[]
  brands                 Brand[]
  units                  Unit[]
  batches                Batch[]
  serialNumbers          SerialNumber[]
  stockTransfers         StockTransfer[]
  stockAdjustments       StockAdjustment[]
  purchaseRequests       PurchaseRequest[]
  goodsReceiveNotes      GoodsReceiveNote[]
  purchaseReturns        PurchaseReturn[]
  salesReturns           SalesReturn[]
  recurringInvoices      RecurringInvoice[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  accounts               Account[]
  products               Product[]
  purchaseOrders         PurchaseOrder[]
  timeEntries            TimeEntry[]
  inventoryLayers        InventoryLayer[]
  complianceTasks        ComplianceTask[]
  projects               Project[]
  projectRequirements    ProjectRequirement[]
  projectEstimations     ProjectEstimation[]
  projectMilestones      ProjectMilestone[]
  projectTasks           ProjectTask[]
  projectMasters         ProjectMaster[]
  projectIssues          ProjectIssue[]
  projectChangeRequests  ProjectChangeRequest[]
  projectRisks           ProjectRisk[]
  projectDocuments       ProjectDocument[]
  projectMeetings        ProjectMeeting[]
  projectTemplates       ProjectTemplate[]
  projectBudgetHistories ProjectBudgetHistory[]
  expenseAuditLogs       ExpenseAuditLog[]
  invoiceAuditLogs       InvoiceAuditLog[]
  documentAuditLogs      DocumentAuditLog[]
  projectBudgets         ProjectBudget[]

  @@map("businesses")
  warranties Warranty[]
  warrantyAttachments WarrantyAttachment[]
  warrantyReminders WarrantyReminder[]
  amcs AMC[]
  amcVisits AMCVisit[]
  amcRenewals AMCRenewal[]
  tickets Ticket[]
  ticketComments TicketComment[]
  ticketAttachments TicketAttachment[]
}
//////////////////////////////////////////////////////
// BUSINESS USERS (User ↔ Business)
//////////////////////////////////////////////////////

model BusinessUser {
  id              String           @id @default(uuid())
  userId          String
  businessId      String
  roleId          String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  //   activities                                   Activity[]
  //   CrmTask relations removed (use crmTasksAssigned/crmTasksCreated below)
  //   CustomerContact moved to contactOwner below
  //   deals                                        Deal[]
  //   leads                                        Lead[]
  business        Business         @relation(fields: [businessId], references: [id])
  role            Role             @relation(fields: [roleId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  userPermissions UserPermission[]

  // Phase2 CRM back-relations
  customerOwner      Customer[]          @relation("CustomerOwner")
  contactOwner       CustomerContact[]   @relation("ContactOwner")
  createdNotes       Note[]              @relation("NoteCreatedBy")
  crmTasksAssigned   CrmTask[]           @relation("CrmTaskAssignedTo")
  crmTasksCreated    CrmTask[]           @relation("CrmTaskCreatedBy")
  leadConversionLogs LeadConversionLog[]
  purchaseRequests   PurchaseRequest[]
  // assignedTo back-relations
  leads              Lead[]
  deals              Deal[]
  activities         Activity[]
  quotations         Quotation[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  timeEntries        TimeEntry[]

  @@unique([userId, businessId])
  @@index([businessId])
  @@map("business_users")
}

//////////////////////////////////////////////////////
// ROLES (Business Scoped)
//////////////////////////////////////////////////////

model Role {
  id              String           @id @default(uuid())
  name            String
  businessId      String
  createdAt       DateTime         @default(now())
  users           BusinessUser[]
  rolePermissions RolePermission[]
  business        Business         @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  action          String
  moduleId        String
  module          Module           @relation(fields: [moduleId], references: [id])
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([moduleId, action])
  @@map("permissions")
}

model Module {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]

  @@map("modules")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id             String       @id @default(uuid())
  businessUserId String
  permissionId   String
  businessUser   BusinessUser @relation(fields: [businessUserId], references: [id])
  permission     Permission   @relation(fields: [permissionId], references: [id])

  @@unique([businessUserId, permissionId])
  @@map("user_permissions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Customer {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS RELATION (REPLACE TENANT)
  //////////////////////////////////////////////////////
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // CUSTOMER DETAILS
  //////////////////////////////////////////////////////
  company         String
  vatNumber       String?
  phone           String?
  website         String?
  group           String?
  currency        String  @default("SYSTEM")
  defaultLanguage String  @default("SYSTEM")

  //////////////////////////////////////////////////////
  // MAIN ADDRESS
  //////////////////////////////////////////////////////
  address String?
  city    String?
  state   String?
  zipCode String?
  country String?

  //////////////////////////////////////////////////////
  // BILLING ADDRESS
  //////////////////////////////////////////////////////
  billingStreet  String?
  billingCity    String?
  billingState   String?
  billingZipCode String?
  billingCountry String?

  //////////////////////////////////////////////////////
  // SHIPPING ADDRESS
  //////////////////////////////////////////////////////
  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingZipCode String?
  shippingCountry String?
  region          Region

  //////////////////////////////////////////////////////
  // UPGRADED CRM ACCOUNT FIELDS
  //////////////////////////////////////////////////////
  industry        String?
  annualRevenue   Float?
  employeeCount   Int?
  accountOwnerId  String?
  accountOwner    BusinessUser?   @relation("CustomerOwner", fields: [accountOwnerId], references: [id])
  accountType     CrmAccountType?
  parentAccountId String?
  parentAccount   Customer?       @relation("CustomerParentChild", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts   Customer[]      @relation("CustomerParentChild")
  linkedinUrl     String?
  facebookUrl     String?
  twitterUrl      String?
  tags            String[]
  description     String?
  lastContactedAt DateTime?
  crmStatus       CrmStatus?
  isDeleted       Boolean         @default(false)
  deletedAt       DateTime?

  //////////////////////////////////////////////////////
  // STATUS + META
  //////////////////////////////////////////////////////
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  invoices            Invoice[]
  leadId              String?              @unique
  leads               Lead[]
  inquiries           Lead[]               @relation("LeadToCustomer")
  creditNotes         CreditNote[]
  customerContacts    CustomerContact[]
  contracts           Contract[]
  deals               Deal[]
  activities          Activity[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  projects            Project[]
  projectRequirements ProjectRequirement[]
  notes               Note[]
  emailLogs           EmailLog[]
  crmTasks            CrmTask[]
  leadConversionLogs  LeadConversionLog[]
  salesReturns        SalesReturn[]
  recurringInvoices   RecurringInvoice[]
  projectMeetings     ProjectMeeting[]
  projectBudgets      ProjectBudget[]

  @@index([businessId])
  @@index([accountOwnerId])
  @@index([parentAccountId])
  @@index([isDeleted])
  @@map("customers")
  warranties Warranty[]
  amcs AMC[]
  tickets Ticket[]
}
// enum Region {
//   INDIA
//   UAE

//////////////////////////////////////////////////////
// INVOICES
//////////////////////////////////////////////////////

model Invoice {
  id            String        @id @default(uuid())
  businessId    String
  customerId    String
  invoiceNumber String
  status        InvoiceStatus @default(UNPAID)
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  currency      String        @default("AED")
  poNumber      String?
  poDate        DateTime?
  soNumber      String?
  soDate        DateTime?

  //NOTE//
  adminNote String?
  terms     String?

  // Regional Taxation & Shipping Fields
  reverseCharge    Boolean? @default(false)
  shippingCharges  Float    @default(0)
  cgst             Float?   @default(0)
  sgst             Float?   @default(0)
  igst             Float?   @default(0)
  tds              Float?   @default(0)
  vatAmount        Float?   @default(0)
  vatPercentage    Float?   @default(0)
  vatType          String?
  emirate          String?
  ewayBillNo       String?
  transportDetails String?

  //totalAmount//
  subtotal         Float  @default(0)
  totalTax         Float  @default(0)
  discount         Float  @default(0)
  grandTotal       Float  @default(0)
  totalCogs        Float? @default(0)
  totalGrossProfit Float? @default(0)

  //Business//
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pdfUrl   String?
  business Business @relation(fields: [businessId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  contactId String?
  contact   CustomerContact? @relation(fields: [contactId], references: [id])

  quotationId String?
  quotation   Quotation? @relation(fields: [quotationId], references: [id])

  salesOrderId   String?
  designTemplate String        @default("modern")
  salesOrder     SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  items          InvoiceItem[]

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  auditLogs    InvoiceAuditLog[]
  salesReturns SalesReturn[]
  payments     Payment[]
  creditNotes  CreditNote[]

  @@unique([businessId, invoiceNumber]) // invoice numbers unique per business
  @@index([businessId])
  @@map("invoices")
}

model InvoiceAuditLog {
  id          String   @id @default(uuid())
  businessId  String
  invoiceId   String
  action      String // Created, Sent, Payment Received, Cancelled
  performedBy String?
  comments    String?  @db.Text
  createdAt   DateTime @default(now())

  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

