//////////////////////////////////////////////////////
// SUBSCRIPTIONS (Manual Billing Ready)
//////////////////////////////////////////////////////

model Subscription {
  id         String             @id @default(uuid())
  businessId String             @unique
  status     SubscriptionStatus @default(INACTIVE)
  startDate  DateTime?
  expiresAt  DateTime?
  planName   String?
  notes      String?
  createdAt  DateTime           @default(now())
  business   Business           @relation(fields: [businessId], references: [id])

  @@map("subscriptions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Settings {
  id                Int      @id @default(autoincrement())
  businessId        String   @unique
  companyName       String
  address           String?
  phone             String?
  email             String?
  website           String?
  trn               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accountName       String?
  accountNumber     String?
  bankAddress       String?
  bankName          String?
  companyLogo       String?
  iban              String?
  swiftCode         String?
  defaultFooterNote String?
  defaultTerms      String?
  invoiceFormat     String   @default("INV-YYYY-MM-DD-COUNT")
  signatureUrl      String?
  leaveTypes        Json?
  overtimeThreshold Float    @default(2)
  currency          String   @default("INR")
  currencySymbol    String   @default("₹")
  invoiceTemplate   String   @default("modern")
  valuationMethod   String   @default("FIFO")

  // Financial Prefixes
  fiscalYear          String?
  invoicePrefix       String?
  creditNotePrefix    String?
  quotationPrefix     String?
  salesOrderPrefix    String?
  purchaseOrderPrefix String?
  paymentPrefix       String?

  // Inventory Settings
  defaultWarehouseId String?
  negativeStock      Boolean @default(false)
  barcodeTracking    Boolean @default(false)
  batchTracking      Boolean @default(false)
  serialTracking     Boolean @default(false)

  // Compliance / Additional Settings
  ifsc               String?
  digitalSignature   String?
  defaultTaxSettings Json?
  exportSettings     Json?
  importSettings     Json?
  reverseCharge      Boolean @default(false)
  placeOfSupply      String?

  busniess Business @relation(fields: [businessId], references: [id])
  users    User[]   @relation("SettingsToUser")
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId    String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  amount        Float
  paymentDate   DateTime
  paymentMode   String
  transactionId String?
  note          String?
  createdAt     DateTime @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdBy     String
  pdfUrl        String?
  //   creditNoteId  String?
  paymentNumber String
  billId        String?
  bill          Bill?    @relation(fields: [billId], references: [id])
  business      Business @relation(fields: [businessId], references: [id])
  //   creditNote    CreditNote? @relation(fields: [creditNoteId], references: [id])
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model CreditNote {
  id String @id @default(uuid())

  ////////////////////////////////////////////////////
  // RELATIONS
  ////////////////////////////////////////////////////
  businessId String
  customerId String?
  invoiceId  String? // nullable (credit may exist without invoice)
  vendorId   String? // for bill credits
  business   Business  @relation(fields: [businessId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id])
  vendor     Vendor?   @relation(fields: [vendorId], references: [id])

  salesReturnId String?
  salesReturn   SalesReturn? @relation(fields: [salesReturnId], references: [id])

  ////////////////////////////////////////////////////
  // CREDIT DATA
  ////////////////////////////////////////////////////
  creditNumber    String
  type            CreditNoteType // 🔥 ADD THIS
  amount          Float
  remainingAmount Float

  reason String?
  status CreditNoteStatus @default(OPEN)
  pdfUrl String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([customerId])
}

model Employee {
  id                 String              @id @default(uuid())
  businessId         String
  name               String
  email              String?
  phone              String?
  designation        String?
  joinDate           DateTime?
  basicSalary        Float
  createdAt          DateTime            @default(now())
  allowance          Json?
  deduction          Json?
  leaveBalance       Json?
  userId             String?             @unique
  accountHolderName  String?
  accountNumber      String?
  bankName           String?
  Code               String?
  bankChangeRequests BankChangeRequest[]
  business           Business            @relation(fields: [businessId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  leaves             Leave[]
  loans              Loan[]
  overtimes          Overtime[]
  payslips           Payslip[]
  attendances        Attendance[]
  timeEntries        TimeEntry[]
  expenses           Expense[]
  amcsAssigned AMC[] @relation("AMCEngineer")
  amcVisits AMCVisit[]
  ticketsAssigned Ticket[] @relation("TicketEngineer")
}
model Attendance {
  id         String    @id @default(uuid())
  businessId String
  employeeId String
  date       DateTime
  status     String
  checkIn    DateTime?
  checkOut   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([businessId, employeeId, date])
  @@index([businessId, date])
  @@map("attendances")
}

model Payslip {
  id            String   @id @default(uuid())
  payrollId     String
  employeeId    String
  basicSalary   Float
  allowance     Float    @default(0)
  deduction     Float    @default(0)
  netSalary     Float
  status        String   @default("pending")
  pdfUrl        String?
  createdAt     DateTime @default(now())
  employeeName  String
  overtimePay   Float    @default(0)
  loanDeduction Float    @default(0)
  employee      Employee @relation(fields: [employeeId], references: [id])
  payroll       Payroll  @relation(fields: [payrollId], references: [id])
}

model Payroll {
  id         String    @id @default(uuid())
  businessId String
  month      Int
  year       Int
  status     String    @default("draft")
  createdAt  DateTime  @default(now())
  payslips   Payslip[]
}

model Leave {
  id         String   @id @default(uuid())
  businessId String
  employeeId String
  leaveCode  String
  date       DateTime
  duration   String
  createdAt  DateTime @default(now())
  status     String   @default("PENDING")
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model BankChangeRequest {
  id                String        @id @default(uuid())
  employeeId        String
  businessId        String
  bankName          String
  accountNumber     String
  accountHolderName String
  status            RequestStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  Code              String
  country           String
  employee          Employee      @relation(fields: [employeeId], references: [id])
}

model Overtime {
  id            String   @id @default(uuid())
  employeeId    String
  businessId    String
  overtimeHours Float
  date          DateTime
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([businessId, employeeId])
}

model Loan {
  id              String   @id @default(uuid())
  employeeId      String
  businessId      String
  totalAmount     Float
  remainingAmount Float
  emiAmount       Float
  startDate       DateTime
  status          String   @default("active")
  createdAt       DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id            String   @id @default(uuid())
  businessId    String
  title         String
  amount        Float
  category      String
  paymentMethod String
  date          DateTime
  notes         String?
  vendorId      String?

  status           String  @default("Draft") // Draft, Submitted, Manager Approval, Finance Approval, Reimbursed, Rejected
  employeeId       String?
  taskId           String?
  department       String?
  costCenter       String?
  managerId        String?
  financeId        String?
  approvalComments String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business  Business     @relation(fields: [businessId], references: [id])
  vendor    Vendor?      @relation(fields: [vendorId], references: [id])
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id])
  employee  Employee?    @relation(fields: [employeeId], references: [id])
  task      ProjectTask? @relation(fields: [taskId], references: [id])
  manager   User?        @relation("ExpenseManager", fields: [managerId], references: [id])
  finance   User?        @relation("ExpenseFinance", fields: [financeId], references: [id])

  auditLogs ExpenseAuditLog[]
}

model ExpenseAuditLog {
  id          String   @id @default(uuid())
  businessId  String
  expenseId   String
  action      String // Created, Submitted, Approved (Manager), Approved (Finance), Reimbursed, Rejected, Edited, Deleted
