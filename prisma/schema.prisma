model Project {
  id               String        @id @default(uuid())
  businessId       String
  projectCode      String        @unique
  projectName      String
  customerId       String
  projectManagerId String?
  department       String?
  categoryId       String?
  typeId           String?
  priority         String?
  status           ProjectStatus @default(ACTIVE)
  budget           Float         @default(0)
  revenue          Float         @default(0)
  expectedProfit   Float         @default(0)
  actualCost       Float         @default(0)

  committedCost    Float @default(0)
  laborCost        Float @default(0)
  materialCost     Float @default(0)
  invoicedRevenue  Float @default(0)
  collectedRevenue Float @default(0)

  estimatedHours       Float     @default(0)
  startDate            DateTime?
  endDate              DateTime?
  completionPercentage Float     @default(0)

  quotationId  String?
  salesOrderId String?

  executionType String? @default("SERVICE") // SERVICE, PRODUCT, HYBRID
  billingMethod String?
  templateId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgetHistories ProjectBudgetHistory[]

  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id])
  projectManager User?            @relation("ProjectManager", fields: [projectManagerId], references: [id])
  quotation      Quotation?       @relation(fields: [quotationId], references: [id])
  salesOrder     SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  template       ProjectTemplate? @relation(fields: [templateId], references: [id])

  milestones       ProjectMilestone[]
  tasks            ProjectTask[]
  timeEntries      TimeEntry[]
  invoices         Invoice[]
  expenses         Expense[]
  purchaseOrders   PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  issues           ProjectIssue[]
  changeRequests   ProjectChangeRequest[]
  risks            ProjectRisk[]
  documents        ProjectDocument[]
  meetings         ProjectMeeting[]
  projectBudget    ProjectBudget?
  warranties Warranty[]
  amcs AMC[]
  tickets Ticket[]
}
model ProjectMilestone {
